# Copy this file to .env and fill in your Gemini API key before running the live model path.

LLM_PROVIDER=gemini
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Optional Gemini settings
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_DELAY_SECONDS=60
# GEMINI_MAX_RETRIES=4
# GEMINI_TIMEOUT_SECONDS=90

# Experiment settings
SYSTEM_RESPONSE_HOURS=4
HUMAN_RESPONSE_HOURS=8
HUMAN_MISS_PROB=0.12
HUMAN_AMBIGUITY_MISS_MULTIPLIER=1.0
HORIZON_HOURS=18
COVER_MIN_HOURS=3
COVER_MAX_HOURS=8
ON_ORDER_MIN_HOURS=2
ON_ORDER_MAX_HOURS=6
BASE_ARRIVAL_SCALE_HOURS=1.0
BASE_ARRIVAL_MIN_HOURS=2
BASE_ARRIVAL_MAX_HOURS=6
DELAY_SCALE_HOURS=3.0
DELAY_MIN_HOURS=4
REALLOCATE_CUTOFF_HOURS=1.5
EXPEDITE_CUTOFF_HOURS=3
EXPEDITE_ARRIVAL_HOURS=1
REORDER_ARRIVAL_HOURS=14
REORDER_FILL_RATE=0.8
