# Copy this file to .env and fill in your Gemini API key before running Gemini.

LLM_PROVIDER=gemini
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE

# Gemini settings
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_DELAY_SECONDS=60
# GEMINI_MAX_RETRIES=4
# GEMINI_TIMEOUT_SECONDS=90
# GEMINI_TEMPERATURE=0

# Final cutoff experiment settings
CUTOFF_SIM_RUNS=100
CUTOFF_HORIZON_DAYS=10
CUTOFF_LOADED_PLANNER_HOURLY_COST=50.0
CUTOFF_HUMAN_REVIEW_MINUTES=30.0
CUTOFF_HYBRID_APPROVAL_MINUTES=10.0
CUTOFF_LLM_PROCESSING_COST=0.25
CUTOFF_RULE_PROCESSING_COST=0.10
# Optional explicit overrides. If unset, human and hybrid are calculated from labor minutes above.
# CUTOFF_HUMAN_PROCESSING_COST=25.0
# CUTOFF_HYBRID_PROCESSING_COST=8.58
CUTOFF_LLM_DELAY_DAYS=0.05
CUTOFF_RULE_DELAY_DAYS=0.05
